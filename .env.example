# Required — get from https://console.groq.com/keys
GROQ_API_KEY=

# Required for PubMed ingestion — your email (NCBI rates non-key users lower)
NCBI_EMAIL=

# Optional — get from https://www.semanticscholar.org/product/api#api-key
# Without it, Semantic Scholar still works but with stricter rate limits
SEMANTIC_SCHOLAR_API_KEY=
